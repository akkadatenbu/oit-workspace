# ===========================
# Backend Environment Variables Template
# ===========================
# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริงของคุณ
# cp .env.example .env

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=SCHEMA_NAME"

# Server Port
PORT=5525

# Session Secret (เปลี่ยนเป็น string สุ่มที่ยาวและซับซ้อน)
SESSION_SECRET="your-very-long-and-random-secret-key-here"

# Google OAuth2
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5525/api/auth/google/callback"

# Node Environment
NODE_ENV="development"
